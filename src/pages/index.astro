---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { getCollection } from "astro:content";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const welcomeEntries = await getCollection("welcome");
const welcomeData = welcomeEntries[0]?.data;

const heroTitle = welcomeData?.title ?? "The first HR-as-a-Service";
const heroSlogan = welcomeData?.slogan ?? "built for SMEs";
const heroDescription =
  welcomeData?.description ??
  "Automate hiring, access pre-qualified candidates, and grow your team - without an internal HR.";
const heroImage =
  welcomeData?.image?.src ??
  "https://images.unsplash.com/photo-1551434678-e076c223a692?w=800&h=800&fit=crop";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="landing-page">
    <Header />
    <main>
      <section id="home" class="hero">
        <div class="hero-grid">
          <div>
            <h1>{heroTitle}</h1>
            <h2>{heroSlogan}</h2>
            <p>{heroDescription}</p>
            <div class="hero-actions">
              <a href="#contact" class="button primary">Start Free Trial</a>
              <a href="#how-it-works" class="button secondary">Learn More</a>
            </div>
          </div>
          <div class="hero-media">
            <img src={heroImage} alt="Team collaboration" loading="eager" />
          </div>
        </div>
      </section>

      <section
        id="how-it-works"
        class="placeholder"
        aria-label="How It Works section placeholder"
      >
      </section>
      <section
        id="benefits"
        class="placeholder"
        aria-label="Benefits section placeholder"
      >
      </section>
      <section
        id="testimonials"
        class="placeholder"
        aria-label="Testimonials section placeholder"
      >
      </section>
      <section
        id="contact"
        class="placeholder"
        aria-label="Contact section placeholder"
      >
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  :global(body.landing-page) {
    font-family:
      Inter,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    line-height: 1.7;
    color: #1e1b4b;
    background: #fff;
  }

  main {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #fdf4ff 0%, #ede9fe 50%, #e0e7ff 100%);
    padding: 4rem 0;
  }

  .hero-grid {
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 4.5rem;
    width: min(1100px, calc(100% - 3rem));
  }

  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #1e1b4b;
  }

  h2 {
    margin: 0 0 1.4rem;
    font-size: clamp(1.8rem, 3.5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #6366f1;
  }

  p {
    margin: 0 0 2rem;
    max-width: 530px;
    font-size: 1.08rem;
    color: #4b5563;
  }

  .hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.6rem;
    border-radius: 0.75rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .button.primary {
    background: #6366f1;
    color: #fff;
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
  }

  .button.primary:hover {
    transform: translateY(-2px);
    background: #4f46e5;
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  }

  .button.secondary {
    border: 2px solid #6366f1;
    color: #6366f1;
    background: rgba(255, 255, 255, 0.8);
  }

  .button.secondary:hover {
    transform: translateY(-2px);
    background: #6366f1;
    color: #fff;
  }

  .hero-media {
    display: flex;
    justify-content: center;
  }

  .hero-media img {
    width: min(500px, 100%);
    border-radius: 1.5rem;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
  }

  .placeholder {
    height: 1px;
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
      width: min(1100px, calc(100% - 2rem));
    }

    .hero-media {
      order: -1;
    }
  }
</style>
