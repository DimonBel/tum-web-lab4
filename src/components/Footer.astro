---
const today = new Date();
---

<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-grid">
      <div>
        <h3>ROCMAN</h3>
        <p>
          The first HR-as-a-Service built for SMEs. Automate hiring and grow
          your team without internal HR.
        </p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#how-it-works">How It Works</a></li>
          <li><a href="#benefits">Benefits</a></li>
          <li><a href="#testimonials">Testimonials</a></li>
        </ul>
      </div>
      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="#">Documentation</a></li>
          <li><a href="#">Support</a></li>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
        </ul>
      </div>
      <div>
        <h4>Connect</h4>
        <div class="social-links">
          <a href="#">LinkedIn</a>
          <a href="#">Twitter</a>
          <a href="#">Facebook</a>
        </div>
      </div>
    </div>
    <div class="copyright">
      <p>
        &copy; {today.getFullYear()} ROCMAN. All rights reserved. HR-as-a-Service
        for SMEs.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0f172a;
    color: rgba(255, 255, 255, 0.8);
    padding: 3.5rem 0 2.25rem;
  }

  .footer-content {
    margin: 0 auto;
    width: min(1100px, calc(100% - 3rem));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2rem;
  }

  h3,
  h4 {
    margin: 0 0 1rem;
    color: #fff;
  }

  h3 {
    font-size: 1.5rem;
    font-weight: 800;
  }

  h4 {
    font-size: 1.05rem;
    font-weight: 700;
  }

  p,
  li,
  a {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  a {
    color: rgba(255, 255, 255, 0.76);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: #fff;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .copyright {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .copyright p {
    margin: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-content {
      width: min(1100px, calc(100% - 2rem));
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
